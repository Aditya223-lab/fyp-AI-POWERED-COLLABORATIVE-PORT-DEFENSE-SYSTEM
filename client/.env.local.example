# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32   (or any 32+ char random string)
NEXTAUTH_SECRET=replace-me-with-32-char-random-string

# --- Spring Boot backend (REST + SSE) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_SSE_URL=http://localhost:8080/api/events/threats

# --- Admin allowlist (comma-separated emails) ---
ADMIN_EMAILS=paudel.asal00@gmail.com

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (https://github.com/settings/developers -> New OAuth App) ---
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Khalti (https://test-admin.khalti.com -> Settings -> Keys) ---
# Use sandbox keys. The "Secret Key" stays server-side; never expose it.
KHALTI_SECRET_KEY=
NEXT_PUBLIC_KHALTI_BASE_URL=https://dev.khalti.com/api/v2
NEXT_PUBLIC_APP_URL=http://localhost:3000
